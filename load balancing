# --- 1. Target Group ---
# This defines where the ALB sends traffic and how it checks for health
resource "aws_target_group" "web_tg" {
  name     = "${locals.project}-web-tg"
  port     = 80
  protocol = "http"
  vpc_id   = aws_vpc.main.id # Points to your alpha-vpc

  health_check {
    enabled             = true
    interval            = 30
    path                = "/" # Pings the root index.html we created in User Data
    port                = "traffic-port"
    protocol            = "HTTP"
    timeout             = 5
    healthy_threshold   = 3
    unhealthy_threshold = 3
  }

  tags = merge(locals.common_tags, { Name = "${locals.project}-web-tg" })
}

# --- 2. Target Group Attachment ---
# This registers your 2 EC2 instances into the Target Group
resource "aws_target_group_attachment" "web_attach" {
  count            = 2
  target_group_arn = aws_target_group.web_tg.arn
  target_id        = aws_instance.web[count.index].id
  port             = 80
}

# --- 3. Application Load Balancer (ALB) ---
# This is the internet-facing entry point
resource "aws_lb" "web_alb" {
  name               = "${locals.project}-prod-alb"
  internal           = false
  load_balancer_type = "application"
  security_groups    = [aws_security_group.alb_sg.id]
  
  # Deploying across your two Public Subnets for High Availability
  subnets            = [for s in aws_subnet.public : s.id]

  enable_deletion_protection = false

  tags = merge(locals.common_tags, { Name = "${locals.project}-prod-alb" })
}

# --- 4. ALB Listener ---
# This listens for traffic on Port 80 and forwards it to the Target Group
resource "aws_lb_listener" "web_listener" {
  load_balancer_arn = aws_lb.web_alb.arn
  port              = "80"
  protocol          = "HTTP"

  default_action {
    type             = "forward"
    target_group_arn = aws_target_group.web_tg.arn
  }
}
