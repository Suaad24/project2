resource "aws_cloudwatch_log_group" "web_logs" {
  name              = "/aws/ec2/${locals.project}-web-server"
  retention_in_days = 7 # Best practice: don't keep logs forever to save costs
  tags              = locals.common_tags
}
resource "aws_cloudwatch_metric_alarm" "high_cpu" {
  alarm_name          = "${locals.project}-high-cpu-alarm"
  comparison_operator = "GreaterThanOrEqualToThreshold"
  evaluation_periods  = "2"
  metric_name         = "CPUUtilization"
  namespace           = "AWS/EC2"
  period              = "120"
  statistic           = "Average"
  threshold           = "80" # Alert if CPU is over 80%
  alarm_description   = "This metric monitors ec2 cpu utilization"
  
  dimensions = {
    InstanceId = aws_instance.web[0].id
  }

  # Optional: Link to SNS for Email notifications
  # alarm_actions = [aws_sns_topic.alerts.arn]
}
